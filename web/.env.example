# Copy this file to web/.env and fill in the values from your Supabase project
# (Supabase dashboard → Project Settings → API). Vite only exposes VITE_-prefixed
# vars to the frontend bundle.
#
# VITE_SUPABASE_ANON_KEY is the PUBLIC anon/publishable key — safe to ship in the
# browser. Do NOT put DESK_DB_URL or any Supabase service_role/secret key here;
# those stay backend-only (GitHub Actions secrets for the Python collectors).

VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
