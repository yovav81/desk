# Database connection. Default when unset: sqlite:///desk.db (local dev).
# Hosted example (Postgres, e.g. Supabase/Neon free tier):
# DESK_DB_URL=postgresql+psycopg://user:password@host:5432/dbname
DESK_DB_URL=

# Username seeded/used by init_db() when no users exist yet.
DESK_DEFAULT_USER=owner

# Dedicated Gmail inbox for forwarded emails (collect_email.py).
# GMAIL_APP_PASSWORD is a Gmail "app password" (requires 2FA enabled on the
# account), NOT the account login password.
GMAIL_USER=
GMAIL_APP_PASSWORD=
